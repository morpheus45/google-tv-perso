<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Video surface ───────────────────────────────────────────── -->
    <TextureView
        android:id="@+id/vlc_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- ── Loading spinner ─────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/vlc_loading"
        style="?android:attr/progressBarStyle"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="#4285F4"
        android:visibility="visible" />

    <!-- ── Error message ───────────────────────────────────────────── -->
    <TextView
        android:id="@+id/vlc_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:lineSpacingMultiplier="1.6"
        android:padding="28dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ── Controls overlay ────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/vlc_controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <!-- Gradient top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_gravity="top"
            android:background="@drawable/gradient_top" />

        <!-- Gradient bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom" />

        <!-- ── Top bar ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp">

            <!--
              Back button: plain TextView — no Android Button chrome.
              Background (pill shape) set programmatically in Java via
              GradientDrawable so there is zero yellow-focus highlight.
            -->
            <TextView
                android:id="@+id/vlc_btn_back"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="← Retour"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:focusable="true"
                android:clickable="true"
                android:focusableInTouchMode="false" />

            <!-- Title -->
            <TextView
                android:id="@+id/vlc_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:shadowColor="#EE000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="8" />

            <!-- LIVE badge — red pill -->
            <TextView
                android:id="@+id/vlc_live_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬤  LIVE"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#CCEE3030"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Centre play / pause ────────────────────────────────────
             Uses TextView (not Button) to avoid the Android yellow-
             focus-highlight ring. The circular background (normal /
             focused) is applied in Java with GradientDrawable so the
             focus style is fully under our control.
        ─────────────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/vlc_btn_play"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="⏸"
            android:textSize="34sp"
            android:textColor="#FFFFFFFF"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="false" />

        <!-- ── Bottom progress bar ───────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/vlc_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingBottom="36dp"
            android:paddingTop="4dp">

            <SeekBar
                android:id="@+id/vlc_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#4285F4"
                android:thumbTint="#FFFFFFFF"
                android:secondaryProgressTint="#224285F4"
                android:focusable="false"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/vlc_time_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#DDFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/vlc_time_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#88FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

</FrameLayout>
